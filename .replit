modules = ["web", "bash", "nodejs-22"]
[agent]
expertMode = true
integrations = ["javascript_log_in_with_replit:2.0.0"]

[nix]
channel = "stable-25_05"
packages = ["unzipNLS"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[ports]]
localPort = 1455
externalPort = 3000
exposeLocalhost = true

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[userenv]

[userenv.shared]
SUPER_AGENT_HEARTBEAT_SECRET = "a15bc3a230d7199204285ca2a4138dafb95d785364f079d3ac3dcd497fdb30ed"

[userenv.development]

[userenv.production]

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "run", "start"]
build = ["npm", "run", "build"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
