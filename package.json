{
  "name": "next-js-boilerplate",
  "author": "Ixartz (https://github.com/ixartz)",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev:next": "next dev --turbopack -p 5000 -H 0.0.0.0",
    "dev": "npm run dev:next",
    "build:next": "next build",
    "build": "run-p db-server:memory build:* --race",
    "start": "next start -p 5000 -H 0.0.0.0",
    "build-stats": "cross-env ANALYZE=true npm run build",
    "clean": "rimraf .next out coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:types": "tsc --noEmit --pretty",
    "check:deps": "knip",
    "check:i18n": "i18n-check -l src/locales -s en -u src -f next-intl",
    "commit": "commit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "db-server:file": "pglite-server --db=local.db",
    "db-server:memory": "pglite-server",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "storybook": "storybook dev -p 6006",
    "storybook:test": "vitest run --config .storybook/vitest.config.mts",
    "build-storybook": "storybook build",
    "lighthouse": "unlighthouse-ci --site localhost:3000",
    "test:lighthouse": "run-p start lighthouse --race"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@hookform/resolvers": "^5.2.2",
    "@t3-oss/env-nextjs": "^0.13.11",
    "drizzle-orm": "^0.45.2",
    "next": "^15.5.15",
    "next-intl": "^4.9.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.72.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.16.2",
    "@chromatic-com/playwright": "^0.13.1",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/prompt-cli": "^20.5.0",
    "@electric-sql/pglite-socket": "^0.1.4",
    "@eslint-react/eslint-plugin": "^1.53.1",
    "@faker-js/faker": "^10.4.0",
    "@lingual/i18n-check": "^0.9.3",
    "@next/bundle-analyzer": "^15.5.15",
    "@next/eslint-plugin-next": "^15.5.15",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^9.1.20",
    "@storybook/addon-docs": "^9.1.20",
    "@storybook/addon-vitest": "^9.1.20",
    "@storybook/nextjs-vite": "^9.1.20",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^24.0.10",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "checkly": "^7.10.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-plugin-format": "^1.5.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^9.1.20",
    "knip": "^5.88.1",
    "lefthook": "^2.1.5",
    "npm-run-all2": "^7.0.2",
    "postcss": "^8.5.9",
    "postcss-load-config": "^6.0.1",
    "rimraf": "^6.1.3",
    "semantic-release": "^24.2.9",
    "storybook": "^9.1.20",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "unlighthouse": "^0.17.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "vitest-browser-react": "^1.0.1"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/github"
    ]
  }
}
